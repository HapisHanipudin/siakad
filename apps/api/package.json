{
  "name": "@siakad/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "openapi:generate": "tsx src/scripts/generate-openapi.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node-pg-migrate up --envPath .dev.vars -j ts",
    "db:migrate:down": "node-pg-migrate down --envPath .dev.vars -j ts",
    "db:migrate:create": "node-pg-migrate create --envPath .dev.vars -j ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/scripts/seed_large.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.19.10",
    "@neondatabase/serverless": "^1.0.1",
    "@siakad/shared": "file:../../packages/shared",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "latest",
    "pg": "^8.20.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "node-pg-migrate": "^8.0.4",
    "tsx": "^4.21.0",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
